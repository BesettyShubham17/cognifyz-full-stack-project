<%- include('partials/header') %>

<div class="container py-5">
    <div class="row justify-content-center reveal">
        <div class="col-lg-6">
            <div class="glass-card tilt-card">
                <h3 class="text-gradient fw-bold mb-4" style="font-family:'Poppins',sans-serif;">
                    <i class="fa-solid fa-gear me-2"></i>Account Settings
                </h3>
                <form id="settingsForm">
                    <div class="mb-3">
                        <label class="form-label text-light small fw-bold">Full Name</label>
                        <input type="text" class="form-control glass-input" id="updateName" value="<%= user.name %>">
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-light small fw-bold">Phone Number</label>
                        <input type="text" class="form-control glass-input" id="updatePhone" value="<%= user.phone || '' %>">
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-light small fw-bold">Email</label>
                        <input type="email" class="form-control glass-input" value="<%= user.email %>" disabled>
                        <small class="text-white-50">Email cannot be changed.</small>
                    </div>
                    <button type="submit" class="btn btn-gradient w-100 py-2 fw-bold">
                        <i class="fa-solid fa-floppy-disk me-2"></i>Save Changes
                    </button>
                    <div id="settingsMsg" class="mt-3 text-center"></div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
document.getElementById('settingsForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = document.getElementById('updateName').value.trim();
    const phone = document.getElementById('updatePhone').value.trim();
    const msg = document.getElementById('settingsMsg');
    const btn = e.target.querySelector('button[type="submit"]');

    if (!name) {
        msg.innerHTML = '<span class="text-warning">Name is required.</span>';
        return;
    }

    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving...';

    try {
        await axios.put('/api/users/<%= user._id %>', { name, phone });
        msg.innerHTML = '<span class="text-success"><i class="fa-solid fa-check-circle me-1"></i>Settings updated successfully!</span>';
        setTimeout(() => window.location.reload(), 1000);
    } catch (error) {
        msg.innerHTML = '<span class="text-danger">Update failed. Please try again.</span>';
    }
    btn.disabled = false;
    btn.innerHTML = '<i class="fa-solid fa-floppy-disk me-2"></i>Save Changes';
});
</script>

<%- include('partials/footer') %>
