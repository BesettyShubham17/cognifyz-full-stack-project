<%- include('partials/header') %>

<div class="container py-5">
    <div class="row justify-content-center reveal">
        <div class="col-lg-5">
            <div class="glass-card tilt-card">
                <h3 class="text-center mb-4 text-gradient fw-bold" style="font-family:'Poppins',sans-serif;">
                    <i class="fa-solid fa-key me-2"></i>Forgot Password
                </h3>
                <form id="forgotForm">
                    <div class="mb-4">
                        <label class="form-label text-light small fw-bold">Enter your email address</label>
                        <input type="email" class="form-control glass-input" id="forgotEmail" placeholder="you@example.com" required>
                    </div>
                    <button type="submit" class="btn btn-gradient w-100 py-2 fw-bold">Reset Password</button>
                    <div id="forgotMessage" class="mt-3 text-center"></div>
                </form>
                <div class="text-center mt-4">
                    <span class="text-white-50 small">Remembered? <a href="/login" class="text-info">Login</a></span>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.getElementById('forgotForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = document.getElementById('forgotEmail').value.trim();
    const msg = document.getElementById('forgotMessage');
    const btn = e.target.querySelector('button[type="submit"]');

    if (!email || !/\S+@\S+\.\S+/.test(email)) {
        msg.innerHTML = '<span class="text-warning">Please enter a valid email.</span>';
        return;
    }

    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Sending...';

    try {
        const res = await axios.post('/api/forgot-password', { email });
        msg.innerHTML = `<span class="text-success"><i class="fa-solid fa-check-circle me-1"></i>${res.data.message}</span>`;
    } catch (error) {
        msg.innerHTML = `<span class="text-danger">${error.response?.data?.message || 'Failed'}</span>`;
    }
    btn.disabled = false;
    btn.innerHTML = 'Reset Password';
});
</script>

<%- include('partials/footer') %>
