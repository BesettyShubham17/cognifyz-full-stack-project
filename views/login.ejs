<%- include('partials/header') %>

<div class="container py-5">
    <div class="row justify-content-center reveal">
        <div class="col-lg-5">
            <div class="glass-card tilt-card">
                <h3 class="text-center mb-4 text-gradient fw-bold" style="font-family:'Poppins',sans-serif;">
                    <i class="fa-solid fa-right-to-bracket me-2"></i>Login
                </h3>
                <form id="loginForm">
                    <div class="mb-3">
                        <label class="form-label text-light small fw-bold">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text glass-input-icon"><i class="fa-solid fa-envelope"></i></span>
                            <input type="email" class="form-control glass-input" id="email" placeholder="you@example.com" required>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-light small fw-bold">Password</label>
                        <div class="input-group">
                            <span class="input-group-text glass-input-icon"><i class="fa-solid fa-lock"></i></span>
                            <input type="password" class="form-control glass-input" id="password" placeholder="••••••••" required>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-gradient w-100 py-2 fw-bold">
                        Sign In <i class="fa-solid fa-arrow-right ms-2"></i>
                    </button>
                    <div id="loginMessage" class="mt-3 text-center"></div>
                </form>
                <div class="text-center mt-4">
                    <div class="mb-2"><a href="/forgot-password" class="text-info text-decoration-none small">Forgot Password?</a></div>
                    <span class="text-white-50 small">Don't have an account? <a href="/register" class="text-info">Register</a></span>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.getElementById('loginForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = document.getElementById('email').value.trim();
    const password = document.getElementById('password').value;
    const msg = document.getElementById('loginMessage');
    const btn = e.target.querySelector('button[type="submit"]');

    // Client-side validation (Task 2)
    if (!email || !password) {
        msg.innerHTML = '<span class="text-warning"><i class="fa-solid fa-triangle-exclamation me-1"></i>All fields are required.</span>';
        return;
    }
    if (!/\S+@\S+\.\S+/.test(email)) {
        msg.innerHTML = '<span class="text-warning"><i class="fa-solid fa-triangle-exclamation me-1"></i>Invalid email format.</span>';
        return;
    }

    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Signing in...';
    
    try {
        await axios.post('/api/login', { email, password });
        msg.innerHTML = '<span class="text-success"><i class="fa-solid fa-check-circle me-1"></i>Login successful! Redirecting...</span>';
        setTimeout(() => window.location.href = '/dashboard', 800);
    } catch (error) {
        msg.innerHTML = `<span class="text-danger"><i class="fa-solid fa-xmark me-1"></i>${error.response?.data?.message || 'Login failed'}</span>`;
        btn.disabled = false;
        btn.innerHTML = 'Sign In <i class="fa-solid fa-arrow-right ms-2"></i>';
    }
});
</script>

<%- include('partials/footer') %>
