<%- include('partials/header') %>

<div class="container py-5">
    <div class="row justify-content-center reveal">
        <div class="col-lg-8">
            <div class="glass-card tilt-card">
                <h3 class="text-gradient fw-bold mb-4 text-center" style="font-family:'Poppins',sans-serif;">
                    <i class="fa-solid fa-envelope me-2"></i>Contact Us
                </h3>
                <form id="contactForm">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-light small fw-bold">Your Name</label>
                            <input type="text" class="form-control glass-input" id="contactName" placeholder="John Doe" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-light small fw-bold">Email Address</label>
                            <input type="email" class="form-control glass-input" id="contactEmail" placeholder="you@example.com" required>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-light small fw-bold">Message</label>
                        <textarea class="form-control glass-input" id="contactMessage" rows="5" placeholder="Write your message here..." required></textarea>
                        <small class="text-white-50">Characters: <span id="msg-char-count">0</span></small>
                    </div>
                    <button type="submit" class="btn btn-gradient w-100 py-2 fw-bold">
                        <i class="fa-solid fa-paper-plane me-2"></i>Send Message
                    </button>
                    <div id="contactMsg" class="mt-3 text-center"></div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
// Live character counter (Task 4)
document.getElementById('contactMessage').addEventListener('input', function() {
    document.getElementById('msg-char-count').innerText = this.value.length;
});

document.getElementById('contactForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = document.getElementById('contactName').value.trim();
    const email = document.getElementById('contactEmail').value.trim();
    const message = document.getElementById('contactMessage').value.trim();
    const msg = document.getElementById('contactMsg');
    const btn = e.target.querySelector('button[type="submit"]');

    if (!name || !email || !message) {
        msg.innerHTML = '<span class="text-warning">All fields are required.</span>';
        return;
    }

    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Sending...';

    try {
        await axios.post('/api/contact', { name, email, message });
        msg.innerHTML = '<span class="text-success"><i class="fa-solid fa-check-circle me-1"></i>Message sent successfully! Stored in database.</span>';
        document.getElementById('contactForm').reset();
        document.getElementById('msg-char-count').innerText = '0';
    } catch (error) {
        msg.innerHTML = `<span class="text-danger">${error.response?.data?.message || 'Submission failed'}</span>`;
    }
    btn.disabled = false;
    btn.innerHTML = '<i class="fa-solid fa-paper-plane me-2"></i>Send Message';
});
</script>

<%- include('partials/footer') %>
