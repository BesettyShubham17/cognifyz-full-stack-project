<%- include('partials/header') %>

<div class="container py-5 text-center reveal">
    <div class="glass-card py-5 tilt-card" style="max-width:600px;margin:0 auto;">
        <h1 class="display-1 text-danger fw-bold" style="font-family:'Poppins',sans-serif;">500</h1>
        <h3 class="fw-bold mb-3">Internal Server Error</h3>
        <p class="text-white-50 mb-4">Something went wrong on our end. Please try again later.</p>
        <% if (typeof message !== 'undefined' && message) { %>
            <p class="text-white-50 small"><code><%= message %></code></p>
        <% } %>
        <a href="/" class="btn btn-gradient rounded-pill px-4"><i class="fa-solid fa-home me-2"></i>Return Home</a>
    </div>
</div>

<%- include('partials/footer') %>
