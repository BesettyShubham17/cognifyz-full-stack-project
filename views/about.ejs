<%- include('partials/header') %>

<div class="container py-5">
    <div class="row align-items-center mb-5 reveal">
        <div class="col-lg-6 mb-4 mb-lg-0">
            <span class="badge rounded-pill bg-primary bg-opacity-25 text-info mb-3 px-3 py-2">About Us</span>
            <h2 class="text-gradient fw-bold mb-4" style="font-family:'Poppins',sans-serif;">Cognifyz Technologies</h2>
            <p class="text-light">A leading technology company specializing in Data Science, Artificial Intelligence, Machine Learning and Data Analytics solutions.</p>
            <p class="text-white-50">We provide enterprise-grade skill development and internship programs to help students become industry-ready professionals.</p>
            <a href="/register" class="btn btn-gradient mt-2">Join Our Program</a>
        </div>
        <div class="col-lg-6">
            <div class="row g-3">
                <div class="col-6">
                    <div class="glass-card text-center p-4 tilt-card">
                        <i class="fa-solid fa-users fa-2x text-info mb-2"></i>
                        <h4 class="fw-bold counter" data-target="5000">0</h4>
                        <small class="text-white-50">Students Trained</small>
                    </div>
                </div>
                <div class="col-6">
                    <div class="glass-card text-center p-4 tilt-card">
                        <i class="fa-solid fa-laptop-code fa-2x text-primary mb-2"></i>
                        <h4 class="fw-bold counter" data-target="100">0</h4>
                        <small class="text-white-50">% Practical</small>
                    </div>
                </div>
                <div class="col-6">
                    <div class="glass-card text-center p-4 tilt-card">
                        <i class="fa-solid fa-building fa-2x text-success mb-2"></i>
                        <h4 class="fw-bold counter" data-target="50">0</h4>
                        <small class="text-white-50">Companies Partnered</small>
                    </div>
                </div>
                <div class="col-6">
                    <div class="glass-card text-center p-4 tilt-card">
                        <i class="fa-solid fa-award fa-2x text-warning mb-2"></i>
                        <h4 class="fw-bold counter" data-target="8">0</h4>
                        <small class="text-white-50">Task Modules</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
