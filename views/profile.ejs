<%- include('partials/header') %>

<div class="container py-5">
    <div class="row justify-content-center reveal">
        <div class="col-lg-5 text-center">
            <div class="glass-card tilt-card">
                <div class="d-inline-block p-4 rounded-circle mb-4" style="background:var(--gradient);">
                    <i class="fa-solid fa-user-tie fa-4x text-white"></i>
                </div>
                <h3 class="text-gradient fw-bold" style="font-family:'Poppins',sans-serif;"><%= user.name %></h3>
                <p class="text-white-50"><%= user.email %></p>
                <span class="badge bg-primary rounded-pill px-3 py-2 mb-3"><%= user.role.toUpperCase() %></span>
                <% if (user.phone) { %>
                    <p class="text-white-50 small"><i class="fa-solid fa-phone me-1"></i><%= user.phone %></p>
                <% } %>
                <hr style="border-color:rgba(255,255,255,0.1);">
                <p class="text-white-50 small mb-3">Member since: <%= new Date(user.createdAt).toLocaleDateString('en-US', {year:'numeric', month:'long', day:'numeric'}) %></p>
                <a href="/settings" class="btn btn-outline-info rounded-pill px-4"><i class="fa-solid fa-pen me-2"></i>Edit Profile</a>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
