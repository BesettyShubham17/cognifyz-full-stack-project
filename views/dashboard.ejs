<%- include('partials/header') %>

<div class="container py-5">
    <!-- Header Row -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2 reveal">
        <h2 class="text-gradient fw-bold mb-0" style="font-family:'Poppins',sans-serif;">
            <i class="fa-solid fa-gauge-high me-2"></i>Dashboard
        </h2>
        <button class="btn btn-gradient rounded-pill" onclick="fetchUsers()">
            <i class="fa-solid fa-rotate-right me-1"></i> Refresh
        </button>
    </div>

    <!-- Users Table (Task 5 - CRUD) -->
    <div class="glass-card mb-5 reveal">
        <div class="d-flex justify-content-between mb-3 align-items-center flex-wrap gap-2">
            <h5 class="mb-0 fw-bold"><i class="fa-solid fa-users me-2 text-info"></i>Registered Users</h5>
            <div class="d-flex gap-2 flex-wrap">
                <input type="text" class="form-control glass-input" placeholder="Search..." id="searchUser" style="width:180px;">
                <button class="btn btn-outline-info btn-sm" onclick="sortUsers()"><i class="fa-solid fa-sort me-1"></i>Sort</button>
                <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#createUserModal"><i class="fa-solid fa-plus me-1"></i>Create</button>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0" style="background:transparent;">
                <thead>
                    <tr style="border-bottom:1px solid rgba(255,255,255,0.1);">
                        <th>Name</th><th>Email</th><th>Role</th><th>Actions</th>
                    </tr>
                </thead>
                <tbody id="user-table-body"></tbody>
            </table>
        </div>
        <div class="d-flex justify-content-between align-items-center mt-3">
            <button class="btn btn-outline-light btn-sm" id="prevPage" onclick="changePage(-1)"><i class="fa-solid fa-chevron-left"></i> Prev</button>
            <span id="pageIndicator" class="text-white-50 small">Page 1</span>
            <button class="btn btn-outline-light btn-sm" id="nextPage" onclick="changePage(1)">Next <i class="fa-solid fa-chevron-right"></i></button>
        </div>
    </div>

    <!-- Create User Modal -->
    <div class="modal fade" id="createUserModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content" style="background:rgba(15,23,42,0.95);border:1px solid rgba(255,255,255,0.15);border-radius:16px;">
                <div class="modal-header border-0">
                    <h5 class="modal-title text-gradient fw-bold">Create New User</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="createUserForm">
                        <div class="mb-3">
                            <label class="form-label text-light small">Name</label>
                            <input type="text" class="form-control glass-input" id="createName" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-light small">Email</label>
                            <input type="email" class="form-control glass-input" id="createEmail" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-light small">Password</label>
                            <input type="password" class="form-control glass-input" id="createPassword" required>
                        </div>
                        <button type="submit" class="btn btn-gradient w-100">Create User</button>
                        <div id="createMsg" class="mt-2 text-center"></div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit User Modal -->
    <div class="modal fade" id="editUserModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content" style="background:rgba(15,23,42,0.95);border:1px solid rgba(255,255,255,0.15);border-radius:16px;">
                <div class="modal-header border-0">
                    <h5 class="modal-title text-gradient fw-bold">Edit User</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="editUserForm">
                        <input type="hidden" id="editUserId">
                        <div class="mb-3">
                            <label class="form-label text-light small">Name</label>
                            <input type="text" class="form-control glass-input" id="editName" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-light small">Email</label>
                            <input type="email" class="form-control glass-input" id="editEmail" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-light small">Role</label>
                            <select class="form-control glass-input" id="editRole">
                                <option value="user">User</option>
                                <option value="admin">Admin</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-gradient w-100">Save Changes</button>
                        <div id="editMsg" class="mt-2 text-center"></div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- GitHub Integration (Task 7) -->
        <div class="col-lg-6 mb-4 reveal" style="animation-delay:0.1s;">
            <div class="glass-card tilt-card h-100">
                <h5 class="fw-bold mb-3"><i class="fa-brands fa-github me-2"></i>GitHub Profile Fetcher</h5>
                <p class="text-white-50 small mb-3">External API Integration with rate limiting (10 req/min)</p>
                <div class="input-group mb-3">
                    <input type="text" id="github-username" class="form-control glass-input" placeholder="Enter GitHub Username">
                    <button class="btn btn-outline-info" id="fetch-github" type="button"><i class="fa-solid fa-search me-1"></i>Fetch</button>
                </div>
                <div id="github-profile"></div>
            </div>
        </div>

        <!-- Server Stats (Task 8 - visual) -->
        <div class="col-lg-6 mb-4 reveal" style="animation-delay:0.2s;">
            <div class="glass-card tilt-card h-100">
                <h5 class="fw-bold mb-3"><i class="fa-solid fa-server me-2 text-info"></i>Server Status</h5>
                <div class="mt-3">
                    <div class="d-flex justify-content-between small mb-1"><span>MongoDB</span><span class="text-success"><i class="fa-solid fa-circle"></i> Connected</span></div>
                    <div class="progress mb-3" style="height:4px;background:rgba(255,255,255,0.1);">
                        <div class="progress-bar bg-success" style="width:100%;"></div>
                    </div>
                    <div class="d-flex justify-content-between small mb-1"><span>Cron Jobs</span><span class="text-success"><i class="fa-solid fa-circle"></i> Running</span></div>
                    <div class="progress mb-3" style="height:4px;background:rgba(255,255,255,0.1);">
                        <div class="progress-bar bg-success" style="width:100%;"></div>
                    </div>
                    <div class="d-flex justify-content-between small mb-1"><span>Redis Cache</span><span class="text-warning" id="redis-status"><i class="fa-solid fa-circle"></i> Checking...</span></div>
                    <div class="progress mb-3" style="height:4px;background:rgba(255,255,255,0.1);">
                        <div class="progress-bar bg-warning" style="width:60%;"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
