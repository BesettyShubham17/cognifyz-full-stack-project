<%- include('partials/header') %>

<!-- Hero Section (Task 1/3) -->
<section class="min-vh-100 d-flex align-items-center">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7 mb-5 mb-lg-0">
                <div class="reveal">
                    <span class="badge rounded-pill bg-primary bg-opacity-25 text-info mb-3 px-3 py-2">
                        <i class="fa-solid fa-rocket me-1"></i> Full Stack Development Internship
                    </span>
                    <h1 class="display-3 fw-bold mb-3" style="font-family:'Poppins',sans-serif;">
                        Welcome to<br><span class="text-gradient">Cognifyz Technologies</span>
                    </h1>
                    <p class="lead text-white-50 mb-4" style="max-width:550px;">
                        Complete 8 professional tasks spanning HTML, CSS, JavaScript, Node.js, Express, MongoDB, APIs, and enterprise-grade authentication.
                    </p>
                    <div class="d-flex flex-wrap gap-3 mb-5">
                        <a href="/register" class="btn btn-gradient btn-lg px-4"><i class="fa-solid fa-play me-2"></i>Start Internship</a>
                        <a href="/tasks" class="btn btn-outline-light btn-lg rounded-pill px-4">View Tasks</a>
                    </div>
                </div>

                <!-- Animated Stats -->
                <div class="row g-3 reveal" style="animation-delay:0.3s;">
                    <div class="col-6 col-md-3">
                        <div class="glass-card text-center p-3 tilt-card">
                            <h3 class="text-gradient fw-bold counter" data-target="8">0</h3>
                            <small class="text-white-50">Tasks</small>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="glass-card text-center p-3 tilt-card">
                            <h3 class="text-gradient fw-bold counter" data-target="4">0</h3>
                            <small class="text-white-50">Levels</small>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="glass-card text-center p-3 tilt-card">
                            <h3 class="text-gradient fw-bold counter" data-target="5">0</h3>
                            <small class="text-white-50">Required</small>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="glass-card text-center p-3 tilt-card">
                            <h3 class="text-gradient fw-bold">100%</h3>
                            <small class="text-white-50">Practical</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5 reveal" style="animation-delay:0.2s;">
                <div class="glass-card tilt-card p-5 text-center position-relative overflow-hidden">
                    <div class="glow-circle"></div>
                    <i class="fa-solid fa-laptop-code fa-5x text-gradient mb-4" style="position:relative;z-index:1;"></i>
                    <h3 class="fw-bold" style="position:relative;z-index:1;">Build Real Projects</h3>
                    <p class="text-white-50 mb-0" style="position:relative;z-index:1;">Industry-ready skills through hands-on development</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Section (Task 3) -->
<section class="py-5">
    <div class="container">
        <h2 class="text-center text-gradient fw-bold mb-5 reveal" style="font-family:'Poppins',sans-serif;">What You'll Build</h2>
        <div class="row g-4">
            <div class="col-md-4 reveal" style="animation-delay:0.1s;">
                <div class="glass-card tilt-card h-100 text-center">
                    <i class="fa-solid fa-server fa-3x text-primary mb-3"></i>
                    <h5 class="fw-bold">Backend APIs</h5>
                    <p class="text-white-50 small">Express.js REST APIs with CRUD, authentication, and middleware.</p>
                </div>
            </div>
            <div class="col-md-4 reveal" style="animation-delay:0.2s;">
                <div class="glass-card tilt-card h-100 text-center">
                    <i class="fa-solid fa-database fa-3x text-info mb-3"></i>
                    <h5 class="fw-bold">MongoDB Integration</h5>
                    <p class="text-white-50 small">Full database CRUD with Mongoose schemas and data validation.</p>
                </div>
            </div>
            <div class="col-md-4 reveal" style="animation-delay:0.3s;">
                <div class="glass-card tilt-card h-100 text-center">
                    <i class="fa-solid fa-shield-halved fa-3x text-success mb-3"></i>
                    <h5 class="fw-bold">JWT Authentication</h5>
                    <p class="text-white-50 small">Secure login, registration, protected routes, and session management.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
